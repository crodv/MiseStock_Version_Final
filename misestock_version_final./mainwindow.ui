      <property name="styleSheet">
       <string notr="true">
/* 1. MATAR EL FONDO NEGRO: Forzar a que todo sea verde claro y texto negro */
QWidget {
    background-color: #eafced; 
    color: black;
}

/* 2. PESTAÑAS Y CONTENEDORES: Quitar bordes para que se vea limpio */
QTabWidget::pane {
    border: none;
}
QGroupBox {
    background-color: transparent; /* Ahora sí dejará ver el verde de arriba */
    border: none;
  
    font-weight: bold;
}
QGroupBox::title {
    subcontrol-origin: margin;
} 

/* 3. CAJAS DE TEXTO (Buscar, Cantidad): Para que sean blancas */
QLineEdit, QComboBox, QSpinBox {
    background-color: white;
    color: black;
    border: 1px solid #ccc;
}

/* 4. TABLAS (Productos y Carro): Blancas con cabecera verde fuerte */
QTableWidget {
    background-color: white;
    color: black;
    gridline-color: #d3d3d3;
    border: 1px solid #d3d3d3;
}
QHeaderView::section {
    background-color: #6cda7a; 
    color: black;
    font-weight: bold;
    border: 1px solid #d3d3d3;
}

/* 5. BOTONES BASE: Texto blanco y bordes redondeados */
QPushButton {
    color: white;
    font-weight: bold;
    border: none;
    border-radius: 3px;
  
}
/* EL CARRO DE COMPRAS (Fondo lila) */
QGroupBox#gboxCarroVenta {
    background-color: #e6ccff;
}

/* COLORES DE LOS BOTONES */
/* Cambia estos nombres por los tuyos (ej: btnAgregar, btnQuitar, etc.) */
QPushButton#btnAgregarAlCarro { background-color: #007bff; }  /* Azul */
QPushButton#btnQuitarCarroVenta { background-color: #dc3545; }   /* Rojo */
QPushButton#btnConfirmarVenta { background-color: #28a745; } /* Verde */


/* Estilo para todas las pestañas que NO están seleccionadas */
QTabBar::tab {
    background-color: #bbf7d0; /* El verde clarito de tu prototipo */
    color: black;
    padding: 8px 25px;
    margin-right: 2px;
    border-top-left-radius: 5px;
    border-top-right-radius: 5px;
}

/* Recuperar el AZUL exclusivo para la pestaña activa */
QTabBar::tab:selected {
    background-color: #007bff; /* El azul vibrante de tu diseño */
    color: white;
    font-weight: bold;
}

/* Efecto al pasar el mouse por las pestañas inactivas */
QTabBar::tab:hover:!selected {
    background-color: #86efac; /* Un verde levemente más oscuro al apuntar */
}

/* FONDO AZUL PARA LA ZONA DE BÚSQUEDA Y FILTRO */
QGroupBox#gboxRegistrarVenta {
    background-color: #dbeafe; 
    border: none;
    border-radius: 8px;        
  
}

/* Aseguramos que el título tenga fondo transparente */
QGroupBox#gboxRegistrarVenta::title {
    background-color: transparent;
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 5px;
}
/* CABECERA MORADA SOLO PARA LA TABLA DEL CARRO DE COMPRAS */
QTableWidget#tableCarroVenta QHeaderView::section {
    background-color: #d8b4e2; /* Un morado un poco más oscuro que el fondo para que destaque */
    color: black;
    font-weight: bold;
    border: 1px solid #d3d3d3;
}
/* HACER QUE LOS TEXTOS NO TENGAN FONDO PARCHE */
QLabel {
    background-color: transparent;
    color: black;
}
QGroupBox::title {
    background-color: transparent;
    subcontrol-origin: margin;
    color: black;
}
/* COLOR NARANJO AL SELECCIONAR FILAS EN LAS TABLAS */
QTableWidget::item:selected {
    background-color: #ff9800; /* Naranjo vibrante */
    color: white;              /* Texto blanco para que resalte y se lea perfecto */
}

/* COLOR NARANJO AL SOMBREAR TEXTO EN LAS CAJAS (Buscar, Cantidad, etc.) */
QLineEdit::selection, QSpinBox::selection, QComboBox::selection {
    
	background-color: rgb(255, 186, 101);
    color: white;
}</string>
